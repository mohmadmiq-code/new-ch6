{
  "version": "1.0.1",
  "course": "STAT 102",
  "chapter": "6",
  "title": "المتغيرات العشوائية وتوزيعاتها الاحتمالية",
  "lessons": {
    "6.1": {
      "laws": [
        "X:\\Omega\\to\\mathbb{R}",
        "P(A)=\\dfrac{\\text{عدد النتائج الموافقة}}{\\text{عدد النتائج الكلية}}",
        "F_X(x)=P(X\\le x)"
      ],
      "errors": [
        "خلط بين فضاء العينة ومجموعة قيم المتغير",
        "خلط بين احتمال النقطة والتراكمي"
      ]
    },
    "6.2": {
      "laws": [
        "P(X=x)=\\binom{n}{x}p^x(1-p)^{n-x}",
        "P(X=x)=e^{-\\lambda}\\dfrac{\\lambda^x}{x!}",
        "P(X=x)=\\dfrac{\\binom{K}{x}\\binom{N-K}{n-x}}{\\binom{N}{n}}",
        "E(X)=\\sum xP(X=x)"
      ],
      "errors": [
        "خلط بين ذي الحدين وفوق الهندسي",
        "خلط بين بواسون وذي الحدين",
        "خلط بين التوقع والاحتمال"
      ]
    },
    "6.3": {
      "laws": [
        "z=\\dfrac{x-\\mu}{\\sigma}",
        "P(X>x)=1-\\Phi(z)",
        "P(a<X<b)=\\Phi(z_b)-\\Phi(z_a)",
        "P(X=a)=0"
      ],
      "errors": [
        "خلط في احتمال النقطة للمتغير المستمر",
        "خلط في الطرف الأيمن",
        "خلط في الاستعيار"
      ]
    }
  }
}